{
  "name": "@repo/widget-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -w -p tsconfig.json --preserveWatchOutput",
    "dev": "sh -c 'trap \"kill 0\" EXIT; pnpm build && pnpm build:watch & node --watch dist/index.js'",
    "start": "node dist/index.js",
    "test": "tsc -p tests/tsconfig.json && node --test .test-dist/tests/**/*.test.js"
  },
  "dependencies": {
    "@repo/shared": "workspace:*",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "mysql2": "^3.22.2",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "typescript": "^5.2.2"
  }
}
